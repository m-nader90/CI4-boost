{
    "name": "m-nader90/ci4-boost",
    "description": "CodeIgniter 4 Boost accelerates AI-assisted development by providing the essential context and structure that AI needs to generate high-quality, CI4-specific code.",
    "type": "library",
    "keywords": [
        "codeigniter",
        "codeigniter4",
        "ci4",
        "ai",
        "mcp",
        "boost"
    ],
    "homepage": "https://github.com/m-nader90/CI4-boost",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/m-nader90/CI4-boost/issues",
        "source": "https://github.com/m-nader90/CI4-boost"
    },
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.4"
    },
    "require-dev": {
        "codeigniter4/devkit": "^1.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CodeIgniter\\Boost\\": "src/"
        },
        "files": [
            "src/Boost.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "codeigniter4": {
            "commands": [
                "CodeIgniter\\Boost\\Commands\\BoostInstall",
                "CodeIgniter\\Boost\\Commands\\BoostUpdate",
                "CodeIgniter\\Boost\\Commands\\BoostMcp",
                "CodeIgniter\\Boost\\Commands\\BoostDoctor"
            ]
        }
    },
    "scripts": {
        "lint": "phpstan analyse --memory-limit=-1",
        "test": "phpunit",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
